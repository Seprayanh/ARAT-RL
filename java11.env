# Java 11 Environment Configuration
# Auto-detect Java 11 path for different systems

# Try to find Java 11 using java_home (macOS)
if command -v /usr/libexec/java_home >/dev/null 2>&1; then
    JAVA11_PATH=$(/usr/libexec/java_home -v 11 2>/dev/null)
    # Check if the returned path actually contains Java 11
    if [ -n "$JAVA11_PATH" ]; then
        JAVA_VERSION=$($JAVA11_PATH/bin/java -version 2>&1 | head -n 1)
        if [[ ! "$JAVA_VERSION" =~ "11" ]]; then
            JAVA11_PATH=""
        fi
    fi
fi

# Fallback paths for different systems
if [ -z "$JAVA11_PATH" ]; then
    if [ -d "/opt/homebrew/opt/openjdk@11/libexec/openjdk.jdk/Contents/Home" ]; then
        JAVA11_PATH="/opt/homebrew/opt/openjdk@11/libexec/openjdk.jdk/Contents/Home"
    elif [ -d "/usr/lib/jvm/java-1.11.0-openjdk-amd64" ]; then
        JAVA11_PATH="/usr/lib/jvm/java-1.11.0-openjdk-amd64"
    elif [ -d "/usr/lib/jvm/java-11-openjdk" ]; then
        JAVA11_PATH="/usr/lib/jvm/java-11-openjdk"
    fi
fi

if [ -z "$JAVA11_PATH" ]; then
    echo "Warning: Java 11 not found. Please install Java 11 and update this file."
    echo "Common locations:"
    echo "  macOS (Homebrew): /opt/homebrew/opt/openjdk@11/libexec/openjdk.jdk/Contents/Home"
    echo "  Ubuntu: /usr/lib/jvm/java-1.11.0-openjdk-amd64"
    echo "  Manual install: /usr/lib/jvm/java-11-openjdk"
else
    export JAVA_HOME=$JAVA11_PATH
    export PATH=$JAVA_HOME/bin:$PATH
    echo "Java 11 environment set to: $JAVA_HOME"
fi